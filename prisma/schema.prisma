generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Producto {
  id                String          @id @default(cuid())
  nombre            String
  tiktokVideoUrl    String?
  tiktokVideoId     String?
  tiktokVistas      Int             @default(0)
  precioVenta       Float?
  precioProveedor   Float?
  proveedorUrl      String?
  proveedorNombre   String          @default("AliExpress")
  metaAnunciosCount Int             @default(0)
  imagen            String?
  categoria         String?
  activo            Boolean         @default(true)
  creadoPorUsuario  Boolean         @default(false)
  creadoEn          DateTime        @default(now())
  actualizadoEn     DateTime        @updatedAt
  metricas          MetricaDiaria[]

  @@index([creadoEn])
  @@index([activo])
}

model TendenciaTikTok {
  id        String   @id @default(cuid())
  hashtag   String
  posts     Int      @default(0)
  vistas    Int      @default(0)
  categoria String   @default("Trending")
  fecha     DateTime @default(now())

  @@unique([hashtag, fecha])
  @@index([fecha])
  @@index([vistas])
}

model MetricaDiaria {
  id              String   @id @default(cuid())
  productoId      String
  fecha           DateTime @default(now())
  tiktokVistas    Int      @default(0)
  googleTrends    Int      @default(0)
  metaAnuncios    Int      @default(0)
  precioProveedor Float?
  producto        Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([productoId, fecha])
  @@index([productoId])
  @@index([fecha])
}
